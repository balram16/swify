# Copy this file to .env and fill in your values
# DO NOT commit .env to git

PORT=3000
NODE_ENV=production

# Cloud database (Neon.tech or Render PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname

# OR use individual vars for local dev
DB_USER=postgres
DB_HOST=localhost
DB_NAME=swiftclaim-actual
DB_PASSWORD=your_password
DB_PORT=5432

# Auth
JWT_SECRET=your-strong-random-secret-key-here

# Google AI (Gemini)
GEMINI_API_KEY=your_google_ai_key

# Frontend URL (for CORS) - set to your Vercel URL after deploy
FRONTEND_URL=https://your-frontend.vercel.app

# Blockchain (optional - can leave as default for now)
CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
PROVIDER_URL=http://localhost:8545
PRIVATE_KEY=your_private_key
